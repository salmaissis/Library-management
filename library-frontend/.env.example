# Optional. When unset, the app calls same-origin "/api/..." and relies on
# the Vite dev proxy (see vite.config.js) to forward to the Spring Boot
# backend at http://localhost:8080. Set this if you want the browser to call
# the backend directly instead (requires CORS to be enabled on the backend).
# VITE_API_BASE_URL=http://localhost:8080/api
